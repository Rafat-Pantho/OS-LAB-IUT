echo "=== Display Fibonacci Series ==="
echo -n "Enter number of terms: "
read n

if [ $n -le 0 ]; then
    echo "Please enter a positive number."
elif [ $n -eq 1 ]; then
    echo "Fibonacci Series: 0"
else
    a=0
    b=1
    echo -n "Fibonacci Series: $a $b"
    count=2
    while [ $count -lt $n ]; do
        c=$((a + b))
        echo -n " $c"
        a=$b
        b=$c
        count=$((count + 1))
    done
    echo ""
fi
